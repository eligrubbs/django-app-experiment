# This is a template for the `.env` file that is used as part of local development.
# You can copy this file, rename it to `.env` and fill in the missing values,
# then delete this header.
#
# A special note on variable names. To avoid confusion, ALL variables intended for use by the django
# application itself are prefixed with `FOR_DJANGO`. This may feel annoying, but it helps make clear what
# the purpose of the variables are, and what systems are expecting it. Most variables are clear when they are not
# intended for Django, because those expecting systems use those conventions.
# Something like DATABASE_NAME is clearly for postgres, but since this variable is for the django app to connect to the database
# We prefer to use FOR_DJANGO_DATABASE_NAME
#
###############################################################################


###
# Dockerfile Build
###
# non-root user group and user ID
MY_UID=4323
MY_GID=4323

###
# Django Specific
###

### Django Database
# # In prod, can optionally specifiy entire URL instead of each of the below
# FOR_DJANGO_DATABASE_URL="something"

FOR_DJANGO_DEBUG=True
FOR_DJANGO_DATABASE_NAME="hairbrush_db"
FOR_DJANGO_DATABASE_USER="postgres"
FOR_DJANGO_DATABASE_PASSWORD="dev_password"
FOR_DJANGO_DATABASE_HOST="local_db"
FOR_DJANGO_DATABASE_PORT="5432"


###
# External Database (Postgres)
###
POSTGRES_HOST=${FOR_DJANGO_DATABASE_HOST}
POSTGRES_DB=${FOR_DJANGO_DATABASE_NAME}
POSTGRES_USER=${FOR_DJANGO_DATABASE_USER}
POSTGRES_PASSWORD=${FOR_DJANGO_DATABASE_PASSWORD}
POSTGRES_PORT=${FOR_DJANGO_DATABASE_PORT}
