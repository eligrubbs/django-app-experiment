# This is a template for the `.env` file that is used as part of local development.
# You can copy this file, rename it to `.env` and fill in the missing values,
# then delete this header.
#
# A special note on variable names. To avoid confusion, ALL variables intended for use by the django
# application itself are prefixed with `FOR_DJANGO`. This may feel annoying, but it helps make clear what
# the purpose of the variables are, and what systems are expecting it. Most variables are clear when they are not
# intended for Django, because those expecting systems use those conventions.
# Something like POSTGRES_USER is clearly for postgres, but since this variable is for the django app to connect to the database
# We prefer to use FOR_DJANGO_POSTGRES_USER
#
###############################################################################


###
# Dockerfile Build
###
# non-root user group and user ID
MY_UID=4323
MY_GID=4323

###
# Database
###
FOR_DJANGO_POSTGRES_HOST="local_db"
FOR_DJANGO_POSTGRES_DB="hairbrush_db"
FOR_DJANGO_POSTGRES_USER="postgres"
FOR_DJANGO_POSTGRES_PASSWORD="dev_password"
FOR_DJANGO_POSTGRES_PORT="5432"
