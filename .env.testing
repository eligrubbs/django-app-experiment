# The testing .env file exists for consistency.
# Instead of listing out the arguments in github actions, a file that lives so far away from here,
# edit this file! It makes it easier to keep .env.example and this in sync, since they sit right next to each other
###############################################################################

# When used like `docker compose --env-file=.env.example`, then it can load itself into services with `env_file: ${{ENV_FILENAME}}`
ENV_FILENAME=".env.testing"

###
# Dockerfile Build
# (ignored in testing github workflow)
###
# non-root user group and user ID
MY_UID=4323
MY_GID=4323

###
# Django Specific
###

### Django Database
# # In prod, can optionally specifiy entire URL instead of each of the below
# FOR_DJANGO_DATABASE_URL="something"

FOR_DJANGO_DEBUG=False
FOR_DJANGO_DATABASE_NAME="hairbrush_db_test"
FOR_DJANGO_DATABASE_USER="postgres"
FOR_DJANGO_DATABASE_PASSWORD="test_password"
FOR_DJANGO_DATABASE_HOST="docker_postgres"
# have to connect via 127.0.0.1 ://docs.github.com/en/actions/tutorials/use-containerized-services/use-docker-service-containers#running-jobs-on-the-runner-machine
FOR_DJANGO_DATABASE_PORT="5432"

### Health Check
# # Prevent abuse on health check route by suffixing `/health/` with this string
FOR_DJANGO_HEALTH_CHECK_SECRET="test"

###
# External Database (Postgres)
# (ignored in testing github workflow)
###
POSTGRES_HOST=${FOR_DJANGO_DATABASE_HOST}
POSTGRES_DB=${FOR_DJANGO_DATABASE_NAME}
POSTGRES_USER=${FOR_DJANGO_DATABASE_USER}
POSTGRES_PASSWORD=${FOR_DJANGO_DATABASE_PASSWORD}
POSTGRES_PORT=${FOR_DJANGO_DATABASE_PORT}
